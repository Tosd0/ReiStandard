{
  "name": "@rei-standard/amsg-instant",
  "version": "0.8.0",
  "description": "ReiStandard Active Messaging — agentic-loop framework for instant push. Pluggable per-turn hook + optional blob envelope for oversize payloads. Three-axis push schema (messageKind / messageType / messageSubtype) from @rei-standard/amsg-shared. Auto-emits ReasoningPush when the LLM response carries reasoning_content. Pure Web Crypto. Deployable to Cloudflare Workers / Vercel Edge / Netlify / Node with no flags.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tosd0/ReiStandard",
    "directory": "packages/rei-standard-amsg/instant"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./adapters/cloudflare": {
      "types": "./dist/adapters/cloudflare.d.ts",
      "import": "./dist/adapters/cloudflare.mjs",
      "require": "./dist/adapters/cloudflare.cjs"
    },
    "./adapters/node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.mjs",
      "require": "./dist/adapters/node.cjs"
    },
    "./adapters/netlify": {
      "types": "./dist/adapters/netlify.d.ts",
      "import": "./dist/adapters/netlify.mjs",
      "require": "./dist/adapters/netlify.cjs"
    },
    "./adapters/vercel": {
      "types": "./dist/adapters/vercel.d.ts",
      "import": "./dist/adapters/vercel.mjs",
      "require": "./dist/adapters/vercel.cjs"
    },
    "./blob/memory": {
      "types": "./dist/blob/memory.d.ts",
      "import": "./dist/blob/memory.mjs",
      "require": "./dist/blob/memory.cjs"
    },
    "./blob/d1": {
      "types": "./dist/blob/d1.d.ts",
      "import": "./dist/blob/d1.mjs",
      "require": "./dist/blob/d1.cjs"
    },
    "./blob/kv": {
      "types": "./dist/blob/kv.d.ts",
      "import": "./dist/blob/kv.mjs",
      "require": "./dist/blob/kv.cjs"
    },
    "./blob/upstash": {
      "types": "./dist/blob/upstash.d.ts",
      "import": "./dist/blob/upstash.mjs",
      "require": "./dist/blob/upstash.cjs"
    },
    "./blob/netlify": {
      "types": "./dist/blob/netlify.d.ts",
      "import": "./dist/blob/netlify.mjs",
      "require": "./dist/blob/netlify.cjs"
    },
    "./blob/postgres": {
      "types": "./dist/blob/postgres.d.ts",
      "import": "./dist/blob/postgres.mjs",
      "require": "./dist/blob/postgres.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@rei-standard/amsg-shared": "0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
